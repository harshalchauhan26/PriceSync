# PriceSync — Supabase (Postgres) connection.
# Copy this file to ".env" and fill in your values. ".env" is gitignored.
#
# Easiest: paste the full connection string from the Supabase dashboard
#   Project Settings -> Database -> Connection string -> URI
# Use the "Session pooler" (port 6543) or direct (port 5432). Either works.
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOURPROJECTREF.supabase.co:5432/postgres

# --- OR, instead of SUPABASE_DB_URL, give the pieces and we build the URL ---
# SUPABASE_PROJECT_REF=yourprojectref
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_PORT=5432          # 5432 direct, 6543 pooler

# Web server (unchanged)
HOST=127.0.0.1
PORT=8080
THREADS=16
MAX_UPLOAD_MB=64

# React + Node stack
NODE_HOST=127.0.0.1
NODE_PORT=8090
# Max simultaneous pipeline runs (protects the host). Default 3.
MAX_CONCURRENT_RUNS=3
# NOTE: on cloud hosts (Render) leave NODE_PORT unset — the platform injects PORT
# and the app then binds 0.0.0.0 with secure (HTTPS-only) session cookies.
# NOTE: the Shopify push currency (USD default, CAD for some brands) is stored in
# the DB (meta 'push_cad_brands'), not here — manage it via POST /api/push/cad.

# Email — used to send the mismatch alert sheet.
# For Gmail: SMTP_USER = your gmail, SMTP_PASS = a 16-char App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com
ALERT_TO=recipient@example.com

# Auth — SECRET_KEY signs the session cookie (generate: python -c "import secrets;print(secrets.token_hex(32))").
# On first boot, if there are no users, an admin is created from ADMIN_EMAIL/ADMIN_PASSWORD.
SECRET_KEY=change-me-to-a-long-random-hex
ADMIN_EMAIL=admin@example.com
# Use a STRONG password — this seeds the first owner account on an empty DB.
# Changing it later does NOT update an existing owner UNLESS you also set
# SEED_OWNER_RESET_PASSWORD=1 for one boot (then unset it again).
ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_EMAIL/ADMIN_PASSWORD now bootstrap the PLATFORM SUPER-ADMIN account
# (cross-tenant support role), not a tenant's owner. Set to 1 for a single
# boot to reset the existing super-admin's password to ADMIN_PASSWORD (a
# clean rotation), then remove it. Leave unset normally.
SEED_OWNER_RESET_PASSWORD=

# Self-serve signup is closed platform-wide — every MBO (tenant) is
# provisioned by the platform super-admin via `node scripts/create-tenant.mjs`,
# and every user within a tenant is created from that tenant's owner console.
# /api/register always 403s; Google sign-in only authenticates an
# already-provisioned account, it never auto-creates one.

# Google Sign-In (optional). Create an OAuth 2.0 Client ID (type: Web application)
# at https://console.cloud.google.com/apis/credentials and add your app origin
# (e.g. http://localhost:8090 and your production URL) to "Authorized JavaScript
# origins". Leave blank to hide the Google button on the login page.
GOOGLE_CLIENT_ID=

# Outbound proxy for IP-banned brands (meta list `proxy_brands`, API /api/fetch/proxy).
# Brands on that list fetch through this proxy; everything else goes direct.
# Use a residential/ISP proxy — datacenter IPs are what got banned in the first place.
# Format: http://user:pass@host:port
FETCH_PROXY_URL=

# Fetch relay for IP-banned brands (free Cloudflare Worker — see web/relay/README.md).
# When set on the cloud server, local_only_brands are fetched THROUGH the relay
# instead of skipped. FETCH_RELAY_SECRET must equal the worker's RELAY_SECRET.
FETCH_RELAY_URL=
FETCH_RELAY_SECRET=
