# PriceSync — Supabase (Postgres) connection.
# Copy this file to ".env" and fill in your values. ".env" is gitignored.
#
# Easiest: paste the full connection string from the Supabase dashboard
#   Project Settings -> Database -> Connection string -> URI
# Use the "Session pooler" (port 6543) or direct (port 5432). Either works.
SUPABASE_DB_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.YOURPROJECTREF.supabase.co:5432/postgres

# --- OR, instead of SUPABASE_DB_URL, give the pieces and we build the URL ---
# SUPABASE_PROJECT_REF=yourprojectref
# SUPABASE_DB_PASSWORD=your-db-password
# SUPABASE_DB_PORT=5432          # 5432 direct, 6543 pooler

# Web server (unchanged)
HOST=127.0.0.1
PORT=8080
THREADS=16
MAX_UPLOAD_MB=64

# Email — used to send the mismatch alert sheet.
# For Gmail: SMTP_USER = your gmail, SMTP_PASS = a 16-char App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=you@gmail.com
ALERT_TO=recipient@example.com

# Auth — SECRET_KEY signs the session cookie (generate: python -c "import secrets;print(secrets.token_hex(32))").
# On first boot, if there are no users, an admin is created from ADMIN_EMAIL/ADMIN_PASSWORD.
SECRET_KEY=change-me-to-a-long-random-hex
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
